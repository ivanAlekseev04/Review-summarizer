{
    "name": "review-summarizer",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^10.0.3",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4"
    },
    "scripts": {
        "dev": "bun run index.ts",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "dotenv": "^17.4.2",
        "zod": "^4.4.3"
    },
    "lint-staged": {
        "packages/client/**/*.{ts,tsx}": "packages/client/node_modules/.bin/eslint --fix --config packages/client/eslint.config.js"
    }
}
